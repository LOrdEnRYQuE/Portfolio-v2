generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("CLIENT")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  onboardingData String?   @default("{}") // JSON string for wizard progress
  accounts      Account[]
  agents        Agent[]
  projects      Project[]
  sessions      Session[]
  portalMessages PortalMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      String     @default("ACTIVE")
  health      String     @default("STABLE")
  efficiency  Int        @default(100)
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  documents   Document[]
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages      Stage[]

  @@index([userId])
  @@index([status])
}

model Stage {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("UPCOMING")
  order       Int
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Document {
  id        String   @id @default(cuid())
  title     String
  type      String
  url       String
  size      String?
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Agent {
  id              String                   @id @default(cuid())
  name            String
  description     String?
  personality     String?
  config          String                   @default("{}")
  userId          String
  status          String                   @default("ACTIVE")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  lastProcessedAt DateTime?
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations   AgentConversation[]
  knowledge       AgentKnowledgeDocument[]

  @@index([userId])
}

model AgentKnowledgeDocument {
  id        String   @id @default(cuid())
  agentId   String
  fileName  String
  type      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model AgentConversation {
  id        String         @id @default(cuid())
  agentId   String
  visitorId String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  agent     Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages  AgentMessage[]

  @@index([agentId])
}

model AgentMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime          @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  concept     String
  industry    String
  description String?
  features    String   @default("[]")
  timeline    String?
  stack       String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Asset {
  id        String   @id @default(cuid())
  title     String
  type      String
  ext       String
  size      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model Post {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String?
  content   String
  image     String?
  published Boolean  @default(false)
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model PortalMessage {
  id        String   @id @default(cuid())
  content   String
  role      String   // "user" | "admin"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PortfolioProject {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  description String
  challenge   String?
  solution    String?
  brief       String?
  stack       String   @default("[]") // JSON string
  cover       String
  featured    Boolean  @default(false)
  liveUrl     String?
  githubUrl   String?
  status      String   @default("Live")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  content     String   @default("")
  published   Boolean  @default(false)
  inNavbar    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

